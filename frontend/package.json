    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.0"
  },
  "animateUI": {
    "description": "Animate UI components are added via shadcn CLI and stored locally in src/components/animate-ui/",
    "usage": "npx shadcn@latest add @animate-ui/<component-name>",
    "import": "import { Component } from '@/components/animate-ui/<category>/<component>'",
    "docs": "https://animate-ui.com/docs"
  }
