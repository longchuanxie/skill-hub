# Rate Limiting Configuration

# Enable/disable rate limiting (default: true)
RATE_LIMIT_ENABLED=true

# Redis configuration (optional - for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Public API limits (login, register, send-code, etc.) - IP based
RATE_LIMIT_PUBLIC_WINDOW=60000
RATE_LIMIT_PUBLIC_MAX=10

# Authenticated API limits (user operations) - User ID based
RATE_LIMIT_AUTH_WINDOW=60000
RATE_LIMIT_AUTH_MAX=60

# Sensitive API limits (create, delete, etc.) - User ID based
RATE_LIMIT_SENSITIVE_WINDOW=60000
RATE_LIMIT_SENSITIVE_MAX=20

# External API limits (3rd party integrations) - API Key based
RATE_LIMIT_EXTERNAL_WINDOW=60000
RATE_LIMIT_EXTERNAL_MAX=100
