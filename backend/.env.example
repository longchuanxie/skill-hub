# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/skillhub

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# SMTP Configuration (Email Service)
# Required for password reset, email verification, and notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM_NAME=SkillHub
SMTP_FROM_EMAIL=noreply@skillhub.com

# SMTP Examples:
# Gmail: smtp.gmail.com, port 587, use app-specific password
# Outlook: smtp-mail.outlook.com, port 587
# SendGrid: smtp.sendgrid.net, port 587, use API key as password
# Mailgun: smtp.mailgun.org, port 587

# Rate Limiting (optional)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
